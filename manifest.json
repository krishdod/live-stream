{
  "manifest_version": 3,
  "name": "Live Workspace",
  "version": "2.0",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://localhost:8765/*",
    "ws://localhost:8765/*",
    "https://*.onrender.com/*",
    "wss://*.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
